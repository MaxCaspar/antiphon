# ── Anthropic (claude agent) ─────────────────────────────────────────────────
# Only needed for API-key auth. Leave commented out if you use `claude auth login` (OAuth).
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# ── OpenAI (codex-api agent) ──────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.4
OPENAI_REASONING_EFFORT=medium
OPENAI_VERBOSITY=high

# Optional: custom base URL for API-compatible gateways.
OPENAI_BASE_URL=

# ── Codex-api overrides ───────────────────────────────────────────────────────
# Override executable used for `codex-api` alias (default: codex).
CODEX_API_CMD=codex

# Dedicated Codex home for `codex-api` runs.
# Keeps API-key auth isolated from your default ChatGPT Codex login.
CODEX_API_CODEX_HOME=.codex-api-home

# Legacy model override for `--model` flag (default: gpt-5.4).
CODEX_API_MODEL=

# Legacy verbosity override — `low`, `medium`, `high` (default: high).
# Note: OPENAI_REASONING_EFFORT is ignored if your codex CLI lacks --reasoning-effort support.
CODEX_API_VERBOSITY=
